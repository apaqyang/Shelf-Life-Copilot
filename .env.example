# ---------------------------------------------------------------------------
# LLM provider — pick ONE based on --provider in CLI / make targets.
# ---------------------------------------------------------------------------

# Anthropic Claude (default; --provider anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Moonshot / KIMI (--provider moonshot)
# Get one from https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=sk-xxxxx

# ---------------------------------------------------------------------------
# 企业微信
# ---------------------------------------------------------------------------

# 路径 A：群机器人 webhook（v0.1 自测推荐 — 群主即可创建，不需管理员）
# 创建方式：企微群 → 设置 → 群机器人 → 添加 → 复制 Webhook 地址
# CLI 用法：python -m src.cli --customer customerA --push-webhook "$WECOM_WEBHOOK_URL"
# 或者：设了此 env 后，CLI 不带 --push-webhook 也会自动真推
WECOM_WEBHOOK_URL=

# 路径 B：自建应用 + 回调（v0.5 真实工单链路时启用，需要管理员权限 + 公网回调）
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TEST_GROUP_ID=

# ---------------------------------------------------------------------------
# 应用配置（长跑服务 src/main.py 读这些；uvicorn 启动自动挂调度器）
# ---------------------------------------------------------------------------

APP_ENV=development
LOG_LEVEL=INFO

# ── 持久化 ──────────────────────────────────────────────────────────────
DECISIONS_DB_PATH=data/decisions.db
REPORTS_OUTPUT_DIR=docs/demo_samples

# ── 每日扫描 cron（DailyScheduler）──────────────────────────────────────
SCAN_CUSTOMERS=customerA,customerB
SCAN_HOUR=7
SCAN_MINUTE=0

# ── 月度报告 cron（MonthlyReportScheduler，固定 Asia/Shanghai）────────
MONTHLY_DAY=1
MONTHLY_HOUR=8
MONTHLY_MINUTE=0

# ── LLM 选择（缺 key 时 DailyScheduler 跳过，monthly/webhook 仍跑）──
LLM_PROVIDER=anthropic
