# ---------------------------------------------------------------------------
# LLM provider — pick ONE based on --provider in CLI / make targets.
# ---------------------------------------------------------------------------

# Anthropic Claude (default; --provider anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Moonshot / KIMI (--provider moonshot)
# Get one from https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=sk-xxxxx

# ---------------------------------------------------------------------------
# 企业微信
# ---------------------------------------------------------------------------

# 路径 A：群机器人 webhook（v0.1 自测推荐 — 群主即可创建，不需管理员）
# 创建方式：企微群 → 设置 → 群机器人 → 添加 → 复制 Webhook 地址
# CLI 用法：python -m src.cli --customer customerA --push-webhook "$WECOM_WEBHOOK_URL"
# 或者：设了此 env 后，CLI 不带 --push-webhook 也会自动真推
WECOM_WEBHOOK_URL=

# 路径 B：自建应用 + 回调（v0.5 真实工单链路时启用，需要管理员权限 + 公网回调）
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TEST_GROUP_ID=

# ---------------------------------------------------------------------------
# 应用配置
# ---------------------------------------------------------------------------

APP_ENV=development
LOG_LEVEL=INFO
